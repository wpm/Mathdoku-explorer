{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mathdoku Designer",
  "mainBinaryName": "mathdoku-designer",
  "version": "0.1.0",
  "identifier": "com.mcneill.mathdoku-designer",
  "build": {
    "beforeDevCommand": {
      "script": "cd .. && trunk serve",
      "wait": false,
      "dev": true
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 720,
        "height": 760,
        "minWidth": 640,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
