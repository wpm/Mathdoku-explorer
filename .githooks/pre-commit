#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "==> cargo fmt"
cargo fmt --all
(cd mathdoku-designer && cargo fmt --all)
git add -u

echo "==> cargo clippy (mathdoku)"
cargo clippy --all-targets -- \
  -D warnings \
  -D clippy::all \
  -D clippy::pedantic \
  -D clippy::nursery \
  -D clippy::unwrap_used \
  -D clippy::expect_used \
  -D clippy::panic \
  -D clippy::todo \
  -D clippy::unimplemented \
  -D clippy::dbg_macro \
  -D clippy::print_stdout \
  -D clippy::print_stderr \
  -A clippy::must_use_candidate \
  2>&1

echo "==> cargo doc"
RUSTDOCFLAGS="-D warnings" cargo doc --no-deps 2>&1

echo "==> cargo test"
cargo test --lib 2>&1

echo "==> mathdoku-designer checks"
(cd mathdoku-designer && \
  cargo clippy --all-targets 2>&1 && \
  cargo test 2>&1)

echo "==> Pre-commit checks passed"
