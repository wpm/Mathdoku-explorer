#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "==> cargo fmt"
cargo +nightly fmt --all
(cd mathdoku-designer && cargo +nightly fmt --all)
git add -u

echo "==> cargo clippy (mathdoku)"
cargo clippy --all-targets -- \
  -D warnings \
  -D clippy::all \
  -D clippy::pedantic \
  -D clippy::nursery \
  -D clippy::unwrap_used \
  -D clippy::expect_used \
  -D clippy::panic \
  -D clippy::todo \
  -D clippy::unimplemented \
  -D clippy::dbg_macro \
  -D clippy::print_stdout \
  -D clippy::print_stderr \
  2>&1

echo "==> cargo clippy (mathdoku-designer)"
(cd mathdoku-designer && cargo clippy --all-targets 2>&1)

echo "==> cargo doc"
RUSTDOCFLAGS="-D warnings" cargo doc --no-deps 2>&1

echo "==> cargo test"
cargo test --lib 2>&1

echo "==> cargo test (mathdoku-designer)"
(cd mathdoku-designer && cargo test 2>&1)

echo "==> Pre-commit checks passed"
